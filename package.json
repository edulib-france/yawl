{
  "name": "@edulib-france/yawl",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "homepage": "https://github.com/edulib-france/yawl",
  "description": "Simple, powerful JavaScript analytics",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/yawl.js",
  "module": "./dist/yawl.esm.js",
  "exports": {
    ".": {
      "require": "./dist/yawl.js",
      "import": "./dist/yawl.esm.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "lint": "eslint src; biome ci",
    "lint:fix": "eslint src; biome format --write",
    "publish:npm": "npm run build && npm publish",
    "publish:github": "npm run build && npm publish --registry=https://npm.pkg.github.com --scope=@edulib-france"
  },
  "keywords": [
    "analytics",
    "locations",
    "referral"
  ],
  "authors": [
    "ankane",
    "edulib-france"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edulib-france/yawl.git"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "rollup": "^4.62.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "localforage": "^1.10.0"
  }
}
